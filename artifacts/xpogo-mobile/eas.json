{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_TMDB_KEY": "$EXPO_PUBLIC_TMDB_KEY",
        "EXPO_PUBLIC_FIREBASE_SECRET": "$EXPO_PUBLIC_FIREBASE_SECRET",
        "EXPO_PUBLIC_WEB_DOMAIN": "apps-tmdb.web.app"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
